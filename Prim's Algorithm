#include <iostream>
#include <vector>
#include <queue>
using namespace std;

// Prim's Algorithm
int primMST(int V, vector<vector<pair<int, int>>> adj) {

    vector<bool> inMST(V, false);

    // Min Heap
    priority_queue<
        pair<int, int>,
        vector<pair<int, int>>,
        greater<pair<int, int>>
    > pq;

    int mstCost = 0;

    // {weight, vertex}
    pq.push({0, 0});

    while (!pq.empty()) {

        auto p = pq.top();
        pq.pop();

        int wt = p.first;
        int u = p.second;

        if (!inMST[u]) {

            inMST[u] = true;
            mstCost += wt;

            for (auto x : adj[u]) {

                int v = x.first;
                int w = x.second;

                pq.push({w, v});
            }
        }
    }

    return mstCost;
}

int main() {

    int V = 3;

    vector<vector<pair<int, int>>> adj(V);

    // Small undirected weighted graph

    adj[0].push_back({1, 5});
    adj[1].push_back({0, 5});

    adj[1].push_back({2, 10});
    adj[2].push_back({1, 10});

    adj[0].push_back({2, 15});
    adj[2].push_back({0, 15});

    cout << "Minimum cost of MST = "
         << primMST(V, adj);

    return 0;
}
