#include <iostream>
#include <vector>
#include <list>
using namespace std;

class Graph {
    int size;
    list<int>* l;

public:
    Graph(int size) {
        this->size = size;
        l = new list<int>[size];
    }

    // Add edge for undirected graph
    void addEdge(int u, int v) {
        l[u].push_back(v);
        l[v].push_back(u);
    }

    // Recursive DFS
    void dfsRecursive(int start, vector<bool>& vis) {
        vis[start] = true;

        cout << start << " ";

        for (int neighbour : l[start]) {
            if (!vis[neighbour]) {
                dfsRecursive(neighbour, vis);
            }
        }
    }

    void dfs(int start) {
        vector<bool> vis(size, false);
        dfsRecursive(start, vis);
    }
};

int main() {
    Graph g(4);

    g.addEdge(0, 1);
    g.addEdge(0, 2);
    g.addEdge(1, 3);
    g.addEdge(2, 3);

    cout << "DFS: ";
    g.dfs(0);

    return 0;
}
