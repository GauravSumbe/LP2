#include <iostream>
#include <vector>
using namespace std;

class GraphColoring {
    int V;
    vector<vector<int>> graph;
    vector<int> color;

public:

    GraphColoring(int v) {
        V = v;

        graph.resize(V, vector<int>(V, 0));
        color.resize(V, 0);
    }

    // Add edge
    void addEdge(int u, int v) {
        graph[u][v] = 1;
        graph[v][u] = 1;
    }

    // Check whether color can be assigned
    bool isSafe(int node, int col) {

        for (int i = 0; i < V; i++) {

            // Adjacent vertex has same color
            if (graph[node][i] == 1 &&
                color[i] == col) {

                return false;
            }
        }

        return true;
    }

    // Backtracking + Branch and Bound
    bool solve(int node, int m) {

        // All vertices colored
        if (node == V) {
            return true;
        }

        // Try all colors
        for (int col = 1; col <= m; col++) {

            // Branch Condition
            if (isSafe(node, col)) {

                // Assign color
                color[node] = col;

                // Recursive call
                if (solve(node + 1, m)) {
                    return true;
                }

                // Backtracking
                color[node] = 0;
            }
        }

        return false;
    }

    void graphColoring(int m) {

        if (solve(0, m)) {

            cout << "Solution Exists\n";

            for (int i = 0; i < V; i++) {

                cout << "Vertex "
                     << i
                     << " -> Color "
                     << color[i]
                     << endl;
            }
        }
        else {
            cout << "Solution Does Not Exist";
        }
    }
};

int main() {

    int V = 4;

    GraphColoring g(V);

    // Graph
    g.addEdge(0, 1);
    g.addEdge(0, 2);
    g.addEdge(1, 2);
    g.addEdge(1, 3);

    int m = 3; // Number of colors

    g.graphColoring(m);

    return 0;
}
