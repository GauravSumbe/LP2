#include <iostream>
#include <vector>
#include <list>
using namespace std;

class Graph {
    int size;
    list<int>* l;

public:
    Graph(int size) {
        this->size = size;
        l = new list<int>[size];
    }

    // Add edge for undirected graph
    void addEdge(int u, int v) {
        l[u].push_back(v);
        l[v].push_back(u);
    }

    // Recursive BFS
    void bfsRecursive(vector<int>& q, vector<bool>& vis) {

        // Base condition
        if (q.empty()) {
            return;
        }

        // Get front element
        int u = q.front();

        // Remove front element
        q.erase(q.begin());

        // Print current vertex
        cout << u << " ";

        // Visit all neighbours
        for (int neighbour : l[u]) {

            if (!vis[neighbour]) {
                vis[neighbour] = true;
                q.push_back(neighbour);
            }
        }

        // Recursive call
        bfsRecursive(q, vis);
    }

    // BFS Traversal
    void bfs(int start) {

        vector<bool> vis(size, false);
        vector<int> q;

        vis[start] = true;
        q.push_back(start);

        bfsRecursive(q, vis);
    }
};

int main() {

    Graph g(4);

    g.addEdge(0, 1);
    g.addEdge(0, 2);
    g.addEdge(1, 3);
    g.addEdge(2, 3);

    cout << "BFS: ";

    g.bfs(0);

    return 0;
}
