#include <iostream>
#include <vector>
#include <climits>
using namespace std;

int ans = INT_MAX;

// TSP using Backtracking
void tsp(vector<vector<int>>& graph,
         vector<bool>& vis,
         int curr,
         int count,
         int cost,
         int start,
         int n) {

    // If all cities visited and edge exists to start
    if (count == n && graph[curr][start] > 0) {

        ans = min(ans, cost + graph[curr][start]);
        return;
    }

    // Visit all unvisited cities
    for (int i = 0; i < n; i++) {

        if (!vis[i] && graph[curr][i] > 0) {

            vis[i] = true;

            tsp(graph,
                vis,
                i,
                count + 1,
                cost + graph[curr][i],
                start,
                n);

            // Backtrack
            vis[i] = false;
        }
    }
}

int main() {

    int n = 4;

    // Adjacency Matrix
    vector<vector<int>> graph = {
        {0, 10, 15, 20},
        {10, 0, 35, 25},
        {15, 35, 0, 30},
        {20, 25, 30, 0}
    };

    vector<bool> vis(n, false);

    int start = 0;

    vis[start] = true;

    tsp(graph, vis, start, 1, 0, start, n);

    cout << "Minimum Cost = " << ans;

    return 0;
}
